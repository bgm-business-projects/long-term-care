NUXT_DATABASE_URL=postgresql://ltc_user:ltc_password@localhost:15432/ltc_db
NUXT_BETTER_AUTH_SECRET=random-secret-32-chars
NUXT_BETTER_AUTH_URL=http://localhost:3000
NUXT_GOOGLE_CLIENT_ID=your-google-client-id
NUXT_GOOGLE_CLIENT_SECRET=your-google-client-secret
NUXT_RESEND_API_KEY=re_your_resend_api_key
NUXT_RESEND_FROM_EMAIL=YourApp <noreply@yourdomain.com>

# Storage (MinIO)
NUXT_R2_ENDPOINT=http://localhost:19000
NUXT_R2_ACCESS_KEY_ID=ltc_access_key
NUXT_R2_SECRET_ACCESS_KEY=ltc_secret_key
NUXT_R2_BUCKET_NAME=ltc-files
NUXT_R2_PUBLIC_URL=http://localhost:19000/ltc-files

# Redis (Upstash REST format for prod; for local docker use upstash-local-proxy or replace)
UPSTASH_REDIS_REST_URL=http://localhost:16379
UPSTASH_REDIS_REST_TOKEN=local-dev-token
