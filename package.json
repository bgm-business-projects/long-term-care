{
  "name": "myapp",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "vue-tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx --env-file=.env scripts/migrate.ts",
    "db:reset": "npx tsx scripts/reset-and-migrate.ts",
    "db:seed": "npx tsx --env-file=.env scripts/seed.ts",
    "db:seed:test": "npx tsx --env-file=.env scripts/seed-test-data.ts",
    "db:clear:test": "npx tsx --env-file=.env scripts/clear-test-data.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/ui": "^4",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/sitemap": "^7.6.0",
    "animejs": "^4.3.6",
    "better-auth": "^1.5.1",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "ioredis": "^5.10.0",
    "leaflet": "^1.9.4",
    "nuxt": "^4.3.1",
    "postgres": "^3.4.7",
    "rate-limiter-flexible": "^10.0.1",
    "resend": "^6.9.3",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.28",
    "vue-advanced-cropper": "^2.8.9",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.95",
    "@types/leaflet": "^1.9.14",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5"
  }
}
