# Dokploy 部署 — 環境變數範本
# 把這些值填到 Dokploy → Environment Variables 即可（不要 commit 真實值）

# ── 資料庫 ──
POSTGRES_USER=ltc_user
POSTGRES_PASSWORD=請填一個強密碼
POSTGRES_DB=ltc_db

# ── better-auth ──
# 用 `openssl rand -hex 32` 產生
NUXT_BETTER_AUTH_SECRET=請填 64 字元隨機字串
# 對外網址（含 https:// 不要結尾斜線）
NUXT_BETTER_AUTH_URL=https://ltc.example.com

# ── 檔案儲存（內建 MinIO） ──
MINIO_ROOT_USER=ltc_minio_admin
MINIO_ROOT_PASSWORD=請填另一個強密碼
NUXT_R2_BUCKET_NAME=ltc-files
# MinIO 對外網址：要能讓瀏覽器直接抓檔（GET /<bucket>/<key>）
# 兩種做法擇一：
#   1) 給 MinIO 獨立 subdomain：https://files.example.com
#   2) 用 Traefik 把 /files/* 反代到 minio:9000
NUXT_R2_PUBLIC_URL=https://files.example.com

# ── Google OAuth（選填） ──
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=

# ── Resend Email（選填，未設會在 console 印出 email 內容） ──
NUXT_RESEND_API_KEY=
NUXT_RESEND_FROM_EMAIL=noreply@example.com

# ── 進階 ──
# 部署時跳過自動 migration（設 1 跳過）
SKIP_MIGRATE=0
